<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AmbientWatch</title>
<script src="https://cdn.jsdelivr.net/npm/mqtt@5.10.1/dist/mqtt.min.js"></script>
<style>
:root{--bg:#07111f;--sur:#0d1c30;--sur2:#112039;--bd:rgba(99,179,237,.10);--bdh:rgba(99,179,237,.28);--ac:#63b3ed;--acd:rgba(99,179,237,.12);--wa:#f6ad55;--wad:rgba(246,173,85,.14);--co:#76e4f7;--cod:rgba(118,228,247,.12);--gn:#68d391;--rd:#fc8181;--t1:#edf2ff;--t2:#8bacc8;--t3:#3a5270;--r:14px;--rs:9px}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--t1);min-height:100vh;-webkit-font-smoothing:antialiased}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(99,179,237,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(99,179,237,.03) 1px,transparent 1px);background-size:40px 40px}
.wrap{max-width:1360px;margin:0 auto;padding:0 20px 80px;position:relative;z-index:1}
header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;padding:24px 0 26px;border-bottom:1px solid var(--bd);margin-bottom:28px}
.brand{display:flex;align-items:center;gap:12px}
.bico{width:42px;height:42px;border-radius:11px;background:var(--acd);border:1px solid var(--bdh);display:grid;place-items:center;font-size:1.3rem}
.btxt h1{font-size:1.2rem;font-weight:700;letter-spacing:-.02em}
.btxt p{font-size:.72rem;color:var(--t3);margin-top:2px}
.hright{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.badge{display:flex;align-items:center;gap:7px;padding:7px 13px;border-radius:999px;border:1px solid var(--bd);background:var(--sur);font-family:monospace;font-size:.7rem;color:var(--t2);transition:all .3s}
.badge.ok{border-color:rgba(104,211,145,.3);color:var(--gn)}
.badge.er{border-color:rgba(252,129,129,.3);color:var(--rd)}
.dot{width:6px;height:6px;border-radius:50%;background:var(--t3);flex-shrink:0;transition:background .3s}
.badge.ok .dot{background:var(--gn);animation:bk 2s infinite}
.badge.er .dot{background:var(--rd)}
@keyframes bk{0%,100%{opacity:1}50%{opacity:.25}}
.btn{display:flex;align-items:center;gap:7px;padding:8px 16px;border-radius:var(--rs);border:1px solid var(--bdh);background:var(--acd);color:var(--ac);font-size:.82rem;font-weight:500;cursor:pointer;transition:all .18s;white-space:nowrap;font-family:inherit}
.btn:hover{background:rgba(99,179,237,.22)}
.mpanel{background:var(--sur);border:1px solid var(--bd);border-radius:var(--r);padding:20px 22px;margin-bottom:24px;display:none}
.mpanel.show{display:block}
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.fg{display:flex;flex-direction:column;gap:5px}
.fg label{font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--t3)}
.fg input{background:var(--bg);border:1px solid var(--bd);border-radius:var(--rs);padding:9px 12px;color:var(--t1);font-size:.87rem;outline:none;transition:border .2s;font-family:inherit}
.fg input:focus{border-color:var(--ac)}
.btnfull{width:100%;margin-top:14px;justify-content:center;padding:10px;font-size:.9rem;font-weight:600}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:18px}
.rcard{background:var(--sur);border:1px solid var(--bd);border-radius:var(--r);padding:22px;position:relative;overflow:hidden;transition:border-color .25s;animation:ci .35s ease both}
@keyframes ci{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
.rcard::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--ac),transparent);opacity:0;transition:opacity .3s}
.rcard:hover{border-color:var(--bdh)}
.rcard:hover::after{opacity:1}
.rcard.online{border-color:rgba(99,179,237,.18)}
.rcard.offline{border-color:rgba(252,129,129,.18)}
.rcard.offline::after{background:linear-gradient(90deg,transparent,var(--rd),transparent);opacity:.6}
.glow{position:absolute;width:180px;height:180px;border-radius:50%;top:-50px;right:-50px;pointer-events:none;background:rgba(99,179,237,.06);filter:blur(40px)}
.chead{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px}
.cinfo{flex:1;min-width:0}
.clbl{font-size:1rem;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ctop{font-family:monospace;font-size:.63rem;color:var(--t3);margin-top:3px}
.cico{width:38px;height:38px;border-radius:10px;background:var(--acd);border:1px solid var(--bdh);display:grid;place-items:center;font-size:1rem;flex-shrink:0;margin-left:10px}
.chip{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:999px;font-size:.65rem;font-weight:500;margin-top:5px;border:1px solid transparent}
.chip.online{background:rgba(104,211,145,.09);border-color:rgba(104,211,145,.25);color:var(--gn)}
.chip.offline{background:rgba(252,129,129,.09);border-color:rgba(252,129,129,.25);color:var(--rd)}
.chip.wait{background:rgba(58,82,112,.3);border-color:rgba(99,179,237,.1);color:var(--t3)}
.chip .cd{width:5px;height:5px;border-radius:50%;background:currentColor}
.chip.online .cd{animation:bk 2s infinite}
.metrics{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.met{background:var(--sur2);border:1px solid var(--bd);border-radius:var(--rs);padding:14px}
.met.t{border-left:2px solid var(--wa)}
.met.h{border-left:2px solid var(--co)}
.mlbl{font-size:.62rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px}
.met.t .mlbl{color:var(--wa)}
.met.h .mlbl{color:var(--co)}
.mval{font-family:monospace;font-size:1.9rem;font-weight:700;line-height:1;transition:all .4s}
.munit{font-size:.62rem;color:var(--t3);margin-top:3px}
.bwrap{margin-top:8px}
.blbl{display:flex;justify-content:space-between;font-size:.58rem;color:var(--t3);margin-bottom:3px}
.btrk{height:3px;background:var(--bd);border-radius:2px;overflow:hidden}
.bfil{height:100%;border-radius:2px;transition:width .6s cubic-bezier(.4,0,.2,1)}
.met.t .bfil{background:linear-gradient(90deg,#f6e05e,#ed8936)}
.met.h .bfil{background:linear-gradient(90deg,#76e4f7,#63b3ed)}
.cfooter{display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid var(--bd)}
.lupd{font-family:monospace;font-size:.62rem;color:var(--t3)}
.ibtn{width:28px;height:28px;border-radius:7px;background:transparent;border:1px solid var(--bd);color:var(--t3);display:grid;place-items:center;cursor:pointer;font-size:.75rem;transition:all .18s;font-family:inherit}
.ibtn:hover{background:var(--sur2);border-color:var(--bdh);color:var(--t2)}
.ibtn.del:hover{border-color:rgba(252,129,129,.4);color:var(--rd);background:rgba(252,129,129,.08)}
.addcard{border:2px dashed var(--bd);border-radius:var(--r);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:36px 20px;min-height:260px;cursor:pointer;background:transparent;color:var(--t3);transition:all .22s;animation:ci .35s ease both}
.addcard:hover{border-color:var(--bdh);color:var(--ac);background:var(--acd)}
.addico{width:48px;height:48px;border-radius:12px;border:2px dashed currentColor;display:grid;place-items:center;font-size:1.4rem;transition:transform .22s}
.addcard:hover .addico{transform:scale(1.08) rotate(6deg)}
.addcard span{font-size:.83rem;font-weight:500}
.addcard small{font-size:.7rem}
.overlay{position:fixed;inset:0;z-index:200;background:rgba(7,17,31,.88);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .22s}
.overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--sur);border:1px solid var(--bdh);border-radius:18px;padding:28px;width:100%;max-width:440px;box-shadow:0 24px 56px rgba(0,0,0,.7);transform:scale(.95) translateY(12px);transition:transform .22s}
.overlay.open .modal{transform:scale(1) translateY(0)}
.modal h2{font-size:1.1rem;font-weight:700;margin-bottom:4px}
.modal>p{font-size:.79rem;color:var(--t2);margin-bottom:18px}
.irow{display:flex;gap:7px;flex-wrap:wrap}
.iopt{width:38px;height:38px;border-radius:8px;border:1px solid var(--bd);background:var(--bg);font-size:1rem;cursor:pointer;display:grid;place-items:center;transition:all .15s}
.iopt:hover,.iopt.sel{border-color:var(--ac);background:var(--acd)}
.macts{display:flex;gap:9px;margin-top:18px}
.bcancel{flex:1;padding:9px;border-radius:var(--rs);border:1px solid var(--bd);background:transparent;color:var(--t2);font-size:.87rem;cursor:pointer;transition:all .18s;font-family:inherit}
.bcancel:hover{border-color:var(--bdh);color:var(--t1)}
.bok{flex:2;padding:9px;border-radius:var(--rs);border:1px solid var(--ac);background:var(--acd);color:var(--ac);font-size:.87rem;font-weight:600;cursor:pointer;transition:all .18s;font-family:inherit}
.bok:hover{background:rgba(99,179,237,.25)}
#toasts{position:fixed;bottom:22px;right:20px;display:flex;flex-direction:column;gap:8px;z-index:300}
.toast{padding:10px 16px;border-radius:9px;font-size:.79rem;font-weight:500;border:1px solid;animation:ti .25s ease;max-width:280px}
@keyframes ti{from{opacity:0;transform:translateX(14px)}to{opacity:1;transform:none}}
.toast.ok{background:rgba(104,211,145,.08);border-color:rgba(104,211,145,.3);color:var(--gn)}
.toast.er{background:rgba(252,129,129,.08);border-color:rgba(252,129,129,.3);color:var(--rd)}
.toast.inf{background:var(--acd);border-color:var(--bdh);color:var(--ac)}
@media(max-width:600px){.grid{grid-template-columns:1fr}header{flex-direction:column;align-items:flex-start}.hright{width:100%}.cgrid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="brand">
      <div class="bico">🌡️</div>
      <div class="btxt"><h1>AmbientWatch</h1><p>Monitoramento via ESP32 + MQTT</p></div>
    </div>
    <div class="hright">
      <div class="badge" id="badge"><div class="dot"></div><span id="blbl">Desconectado</span></div>
      <button class="btn" id="btnMqtt">⚙️ MQTT</button>
      <button class="btn" id="btnAdd">+ Ambiente</button>
    </div>
  </header>

  <div class="mpanel" id="mpanel">
    <div style="font-size:.88rem;font-weight:600;color:var(--t2);margin-bottom:16px">Configuração MQTT — HiveMQ Cloud</div>
    <div class="cgrid">
      <div class="fg"><label>Broker (host)</label><input id="cBroker" placeholder="xxxx.hivemq.cloud"></div>
      <div class="fg"><label>Porta WebSocket TLS</label><input id="cPort" type="number" value="8884"></div>
      <div class="fg"><label>Usuário</label><input id="cUser" placeholder="seu-usuario"></div>
      <div class="fg"><label>Senha</label><input id="cPass" type="password" placeholder="••••••••"></div>
    </div>
    <button class="btn btnfull" id="btnConn">Conectar ao MQTT</button>
  </div>

  <div class="grid" id="grid">
    <div class="addcard" id="addph">
      <div class="addico">+</div>
      <span>Adicionar ambiente</span>
      <small>Clique para monitorar um novo local</small>
    </div>
  </div>
</div>

<div class="overlay" id="ov">
  <div class="modal">
    <h2>Novo Ambiente</h2>
    <p>Configure o ambiente que deseja monitorar via MQTT.</p>
    <div class="fg" style="margin-bottom:12px">
      <label>Nome do Ambiente</label>
      <input id="mLbl" placeholder="ex: Sala de Estar, Quarto, Servidor...">
    </div>
    <div class="fg" style="margin-bottom:6px">
      <label>ID do Ambiente (sem espaços)</label>
      <input id="mTop" placeholder="ex: sala  →  sensors/sala/data">
    </div>
    <div style="font-size:.66rem;color:var(--t3);margin-bottom:14px">Tópico: sensors/<strong id="tprev" style="color:var(--ac)">...</strong>/data</div>
    <div class="fg">
      <label>Ícone</label>
      <div class="irow" id="irow">
        <div class="iopt sel" data-i="🏠">🏠</div>
        <div class="iopt" data-i="🛏️">🛏️</div>
        <div class="iopt" data-i="🍳">🍳</div>
        <div class="iopt" data-i="🖥️">🖥️</div>
        <div class="iopt" data-i="🌿">🌿</div>
        <div class="iopt" data-i="🚿">🚿</div>
        <div class="iopt" data-i="🏋️">🏋️</div>
        <div class="iopt" data-i="🌞">🌞</div>
        <div class="iopt" data-i="⚙️">⚙️</div>
        <div class="iopt" data-i="🌡️">🌡️</div>
      </div>
    </div>
    <div class="macts">
      <button class="bcancel" id="btnCan">Cancelar</button>
      <button class="bok" id="btnSav">✓ Adicionar</button>
    </div>
  </div>
</div>

<div id="toasts"></div>

<script>
var client=null,rooms=JSON.parse(localStorage.getItem('aw_r')||'[]'),mcfg=JSON.parse(localStorage.getItem('aw_m')||'{}'),ico='🏠',TOUT=90000;
function $(i){return document.getElementById(i)}
function sr(){localStorage.setItem('aw_r',JSON.stringify(rooms))}
function sm(){localStorage.setItem('aw_m',JSON.stringify(mcfg))}
function fmt(t){return t?new Date(t).toLocaleTimeString('pt-BR'):'–'}
function toast(m,t,d){t=t||'inf';d=d||3400;var w=$('toasts'),e=document.createElement('div');e.className='toast '+t;e.textContent=m;w.appendChild(e);setTimeout(function(){e.remove()},d)}

function render(){
  var g=$('grid');
  g.querySelectorAll('.rcard').forEach(function(c){c.remove()});
  rooms.forEach(function(r,i){g.insertBefore(mk(r,i),$('addph'))});
}

function mk(r,i){
  var el=document.createElement('div');
  el.className='rcard '+(r.st||'wait');
  el.id='rc-'+r.id;
  var tv=r.temp!=null?r.temp.toFixed(1):'–';
  var hv=r.hum!=null?r.hum.toFixed(1):'–';
  var tp=r.temp!=null?Math.min(100,(r.temp/50)*100).toFixed(1):0;
  var hp=r.hum!=null?Math.min(100,r.hum).toFixed(1):0;
  var sc=r.st==='online'?'online':r.st==='offline'?'offline':'wait';
  var sl=r.st==='online'?'Online':r.st==='offline'?'Offline':'Aguardando';
  el.innerHTML='<div class="glow"></div>'+
    '<div class="chead"><div class="cinfo">'+
    '<div class="clbl">'+r.label+'</div>'+
    '<div class="ctop">sensors/'+r.topic+'/data</div>'+
    '<div class="chip '+sc+'" id="ch-'+r.id+'"><div class="cd"></div>'+sl+'</div>'+
    '</div><div class="cico">'+r.icon+'</div></div>'+
    '<div class="metrics">'+
    '<div class="met t"><div class="mlbl">🌡 Temperatura</div>'+
    '<div class="mval" id="tv-'+r.id+'">'+tv+'</div>'+
    '<div class="munit">graus Celsius</div>'+
    '<div class="bwrap"><div class="blbl"><span>0°</span><span>50°C</span></div>'+
    '<div class="btrk"><div class="bfil" id="tb-'+r.id+'" style="width:'+tp+'%"></div></div></div></div>'+
    '<div class="met h"><div class="mlbl">💧 Humidade</div>'+
    '<div class="mval" id="hv-'+r.id+'">'+hv+'</div>'+
    '<div class="munit">por cento</div>'+
    '<div class="bwrap"><div class="blbl"><span>0%</span><span>100%</span></div>'+
    '<div class="btrk"><div class="bfil" id="hb-'+r.id+'" style="width:'+hp+'%"></div></div></div></div>'+
    '</div>'+
    '<div class="cfooter"><div class="lupd">Atualizado: <span id="up-'+r.id+'">'+fmt(r.lu)+'</span></div>'+
    '<button class="ibtn del" onclick="del('+i+')" title="Remover">✕</button></div>';
  return el;
}

function patch(id,data){
  var r=rooms.find(function(x){return x.id===id});if(!r)return;
  r.temp=data.temperature;r.hum=data.humidity;r.lu=Date.now();r.st='online';
  clearTimeout(r._t);r._t=setTimeout(function(){offline(id)},TOUT);sr();
  var card=$('rc-'+id);if(!card)return;
  card.className='rcard online';
  var ch=$('ch-'+id);ch.className='chip online';ch.innerHTML='<div class="cd"></div>Online';
  $('tv-'+id).textContent=data.temperature.toFixed(1);
  $('hv-'+id).textContent=data.humidity.toFixed(1);
  $('up-'+id).textContent=fmt(r.lu);
  $('tb-'+id).style.width=Math.min(100,(data.temperature/50)*100).toFixed(1)+'%';
  $('hb-'+id).style.width=Math.min(100,data.humidity).toFixed(1)+'%';
}

function offline(id){
  var r=rooms.find(function(x){return x.id===id});if(!r)return;
  r.st='offline';sr();
  var card=$('rc-'+id);if(!card)return;
  card.className='rcard offline';
  var ch=$('ch-'+id);ch.className='chip offline';ch.innerHTML='<div class="cd"></div>Offline';
}

window.del=function(i){
  var r=rooms[i];if(!r)return;
  clearTimeout(r._t);
  if(client&&client.connected)client.unsubscribe('sensors/'+r.topic+'/data');
  rooms.splice(i,1);sr();render();toast('Ambiente removido','inf');
};

function sub(r){
  if(!client||!client.connected)return;
  client.subscribe('sensors/'+r.topic+'/data',function(e){if(!e)console.log('sub ok: '+r.topic)});
}

function conn(){
  var br=$('cBroker').value.trim(),pt=parseInt($('cPort').value)||8884,us=$('cUser').value.trim(),pw=$('cPass').value;
  if(!br){toast('Informe o broker!','er');return;}
  mcfg={br:br,pt:pt,us:us,pw:pw};sm();
  if(client){try{client.end(true)}catch(e){}}
  setBadge('conn');toast('Conectando...','inf');
  var url='wss://'+br+':'+pt+'/mqtt';
  client=mqtt.connect(url,{clientId:'dash_'+Math.random().toString(36).substr(2,8),username:us,password:pw,clean:false,reconnectPeriod:5000,connectTimeout:10000});
  client.on('connect',function(){
    setBadge('ok');toast('MQTT conectado!','ok');
    rooms.forEach(sub);
    $('mpanel').classList.remove('show');
  });
  client.on('error',function(e){setBadge('er');toast('Erro: '+e.message,'er')});
  client.on('close',function(){setBadge('off')});
  client.on('message',function(topic,msg){
    try{
      var d=JSON.parse(msg.toString());
      var parts=topic.split('/');var tid=parts[1];
      var r=rooms.find(function(x){return x.topic===tid});
      if(r)patch(r.id,d);
    }catch(e){}
  });
}

function setBadge(s){
  var b=$('badge'),l=$('blbl');
  b.className='badge';
  if(s==='ok'){b.classList.add('ok');l.textContent='Conectado'}
  else if(s==='er'){b.classList.add('er');l.textContent='Erro'}
  else if(s==='conn'){l.textContent='Conectando...'}
  else{l.textContent='Desconectado'}
}

$('btnMqtt').onclick=function(){
  var p=$('mpanel');p.classList.toggle('show');
  if(p.classList.contains('show')&&mcfg.br){
    $('cBroker').value=mcfg.br||'';$('cPort').value=mcfg.pt||8884;
    $('cUser').value=mcfg.us||'';$('cPass').value=mcfg.pw||'';
  }
};
$('btnConn').onclick=conn;

$('btnAdd').onclick=function(){$('ov').classList.add('open')};
$('addph').onclick=function(){$('ov').classList.add('open')};
$('btnCan').onclick=function(){$('ov').classList.remove('open');$('mLbl').value='';$('mTop').value='';$('tprev').textContent='...'};
$('ov').onclick=function(e){if(e.target===$('ov'))$('ov').classList.remove('open')};

$('mTop').oninput=function(){$('tprev').textContent=this.value.trim()||'...'};

$('irow').onclick=function(e){
  var o=e.target.closest('.iopt');if(!o)return;
  document.querySelectorAll('.iopt').forEach(function(x){x.classList.remove('sel')});
  o.classList.add('sel');ico=o.dataset.i;
};

$('btnSav').onclick=function(){
  var lb=$('mLbl').value.trim(),tp=$('mTop').value.trim().replace(/[^a-z0-9_\-]/gi,'_');
  if(!lb||!tp){toast('Preencha todos os campos!','er');return}
  if(rooms.find(function(r){return r.id===tp})){toast('Ambiente já existe!','er');return}
  rooms.push({id:tp,label:lb,topic:tp,icon:ico,st:'wait',temp:null,hum:null,lu:null});
  sr();render();sub(rooms[rooms.length-1]);
  toast('"'+lb+'" adicionado!','ok');
  $('ov').classList.remove('open');$('mLbl').value='';$('mTop').value='';$('tprev').textContent='...';
};

render();

rooms.forEach(function(r){
  if(r.st==='online'&&r.lu){
    var el=Date.now()-r.lu,rm=TOUT-el;
    if(rm>0)r._t=setTimeout(function(){offline(r.id)},rm);else r.st='offline';
  }
});

